{
  "version": 2,
  "buildCommand": "pip install -r requirements.txt --break-system-packages",
  "outputDirectory": ".",
  "installCommand": "pip install -r requirements.txt --break-system-packages",
  "framework": null,
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/?path=$1"
    }
  ]
}
